{
  "name": "otellocal",
  "version": "0.1.0",
  "description": "A zero-config local OpenTelemetry collector with a built-in UI — trace waterfall, flame graph, service dependency graph, and slow-span detection. No signup, no SaaS, runs entirely on your machine.",
  "scripts": {
    "start": "node src/server.js",
    "demo": "node src/server.js --demo",
    "build": "cd ui && npm install && npm run build && cd .. && node scripts/copy-ui.js"
  },
  "files": [
    "bin",
    "src",
    "public"
  ],
  "keywords": [
    "opentelemetry",
    "otel",
    "tracing",
    "observability",
    "devtools",
    "local",
    "debugging"
  ],
  "author": "Sidharth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sidhu714/otel.git"
  },
  "homepage": "https://github.com/Sidhu714/otellocal#readme",
  "bugs": {
    "url": "https://github.com/Sidhu714/otellocal/issues"
  },
  "type": "module",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@opentelemetry/otlp-transformer": "^0.215.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "module": "^2.0.0",
    "pg": "^8.20.0",
    "ws": "^8.20.0"
  },
  "bin": {
    "otellocal": "bin/otellocal.js"
  },
  "devDependencies": {
    "fs-extra": "^11.3.5"
  }
}
